# Dev-Intelligence — variabili d'ambiente
# Copia questo file in .env e personalizza i valori se necessario.
# Tutti i valori di default sono già impostati per un avvio immediato.

# App
CACHE_EXPIRE=86400
MAX_CATALOG_PAGES=10
DEV_ITALIA_BASE_URL=https://api.developers.italia.it/v1
TRUSTED_PROXIES=

# LLM (opzionali — i default sono già impostati)
MODEL_DIR=/app/models
MODEL_REPO=Qwen/Qwen2.5-Coder-0.5B-Instruct-GGUF
MODEL_FILE=qwen2.5-coder-0.5b-instruct-q4_k_m.gguf
LLM_N_CTX=2048
LLM_N_THREADS=4
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120
SKIP_LLM=false
